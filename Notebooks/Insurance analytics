        "# KPI 1: Diferencia de costo entre fumadores y no fumadores\n",
        "costo_fumadores     = df[df['smoker'] == 'yes']['charges'].mean()\n",
        "costo_no_fumadores  = df[df['smoker'] == 'no']['charges'].mean()\n",
        "diferencia_pct      = ((costo_fumadores - costo_no_fumadores) / costo_no_fumadores * 100).round(1)\n",
        "\n",
        "print('=== KPI 1: Impacto del tabaquismo ===')\n",
        "print(f'Costo promedio fumadores:     ${costo_fumadores:,.2f}')\n",
        "print(f'Costo promedio no fumadores:  ${costo_no_fumadores:,.2f}')\n",
        "print(f'Los fumadores pagan un {diferencia_pct}% más')\n",
        "\n",
        "# KPI 2: Región con mayor costo promedio\n",
        "costo_region = df.groupby('region')['charges'].mean().sort_values(ascending=False)\n",
        "print('\\n=== KPI 2: Costo promedio por región ===')\n",
        "print(costo_region.to_string())\n",
        "print(f'\\nRegión más costosa: {costo_region.idxmax()} (${costo_region.max():,.2f})')\n",
        "\n",
        "# KPI 3: Costo según número de hijos\n",
        "costo_hijos = df.groupby('children')['charges'].mean().round(2)\n",
        "print('\\n=== KPI 3: Costo promedio por número de hijos ===')\n",
        "print(costo_hijos.to_string())"
      ],
